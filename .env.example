# Required
VLLM_API_KEY=your-api-key-here

# Model
MODEL=/models/GLM-5.2-NVFP4
SERVED_MODEL_NAMES="GLM-5.2 GLM-5.2-v11"

# Parallelism
TP_SIZE=8
DCP_SIZE=1              # DCP=1 is stable with LMCache. DCP=4 requires patch_dcp_lmcache.py + patch_dcp_combine.py

# MTP Speculative Decoding
MTP=1
NUM_SPECULATIVE_TOKENS=2

# Memory
GPU_MEMORY_UTILIZATION=0.94
MAX_MODEL_LEN=450000
MAX_NUM_SEQS=16
MAX_NUM_BATCHED_TOKENS=8192

# LMCache
GLM52_ENABLE_LMCACHE=1
GLM52_LMCACHE_CHUNK_SIZE=256       # 256 for DCP=1; 512+ for DCP>1 (must be >= block_size * dcp_size)
GLM52_LMCACHE_L1_GB=48
GLM52_LMCACHE_L2_GB=500
GLM52_LMCACHE_DISK_PATH=/models/.lmcache_disk
LMCACHE_SAVE_DECODE_CACHE=true
PYTHONHASHSEED=0
