# ── GLM-5.2 v12 Dark Devotion + LMCache MP ──
# Based on https://github.com/local-inference-lab/rtx6kpro/blob/master/models/glm5.2_v12.md

# Container / Image
COMPOSE_PROJECT_NAME=glm52-v12
IMAGE=voipmonitor/vllm:glm52-dark-devotion-release-vllmec65667-b12xaaf1891-scale-fix-cu132-20260622
NAME=glm52-v12

# GPU
CUDA_VISIBLE_DEVICES=0,1,2,3,4,5,6,7
GPU_MEMORY_UTILIZATION=0.94
MAX_MODEL_LEN=1024000
MAX_NUM_SEQS=16
MAX_NUM_BATCHED_TOKENS=8192
MAX_CUDAGRAPH_CAPTURE_SIZE=128

# Model paths (host -> container)
HF_CACHE=/mnt/models/huggingface
CACHE_ROOT=/mnt/models/vllm-glm52-v12-cache
MODEL_HOST_PATH=/mnt/models/GLM-5.2-NVFP4
MODEL=/models/GLM-5.2-NVFP4
SERVED_MODEL_NAME=GLM-5.2-v13-lmcache
SERVED_MODEL_NAMES="GLM-5.2-v13-lmcache GLM-5.2-NVFP4"
PORT=5318
VLLM_API_KEY=your-api-key-here

# Parallelism
DCP_SIZE=4                # DCP=4 requires patch_dcp_lmcache.py + patch_dcp_mla_store.py
MTP=1
NUM_SPECULATIVE_TOKENS=3

# Attention
ATTN_BACKEND=B12X_MLA_SPARSE
VLLM_ENABLE_PCIE_ALLREDUCE=1

# LMCache
LMCACHE_HOST_PATH=/mnt/lmcache-l2/l2
LMCACHE_TMP_HOST_PATH=/mnt/lmcache-l2/tmp
GLM52_ENABLE_LMCACHE=1
GLM52_LMCACHE_VERSION=0.4.6
GLM52_LMCACHE_CHUNK_SIZE=1024       # 1024 tokens; O_DIRECT pads to 4096 block size
GLM52_LMCACHE_L1_GB=48              # L1 RAM cache
GLM52_LMCACHE_L1_INIT_GB=8          # Initial L1 allocation (grows on demand)
GLM52_LMCACHE_L2_GB=2800            # L2 NVMe cache capacity
GLM52_LMCACHE_DISK_PATH=/lmcache/l2 # Container-internal path
LMCACHE_SAVE_DECODE_CACHE=true
PYTHONHASHSEED=0
